{
  "rules": {
    "locations": {
      "$userId": {
        ".read": true,
        ".write": "$userId === auth.uid"
      }
    },
    "presence": {
      ".read": true,
      "$userId": {
        ".write": "$userId === auth.uid"
      }
    },
    "sharedLocations": {
      ".read": true,
      "$userId": {
        ".write": "$userId === auth.uid"
      }
    }
  }
}
